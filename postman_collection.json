              }
            ],
            "url": {
              "raw": "https://dummyjson.com/products/categories",
              "protocol": "https",
              "host": ["dummyjson", "com"],
              "path": ["products", "categories"]
            },
            "description": "Returns an array of all available product category objects (slug, name, url). Fetched by the CategoryFilter component and cached for 600 seconds (10 minutes) via RTK Query since this data rarely changes."
          },
          "response": []
        }
      ],
      "description": "Endpoints for fetching product categories used by the CategoryFilter chip bar."
    }
