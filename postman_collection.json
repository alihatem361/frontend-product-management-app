            "description": "Authenticates a user and returns a JWT access token and refresh token. The token is valid for 60 minutes. Use the returned `token` as a Bearer token in the Authorization header for protected endpoints."
          },
          "response": []
        }
      ],
      "description": "Endpoints for user authentication (login / register)."
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text",
                "description": "JWT token returned from the Login request."
              }
            ],
            "url": {
              "raw": "https://dummyjson.com/products?limit=20&skip=0&select=id,title,price,thumbnail,category,rating,stock",
              "protocol": "https",
              "host": ["dummyjson", "com"],
              "path": ["products"],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Number of products to return per page."
                },
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Number of products to skip (page * limit)."
                },
                {
                  "key": "select",
                  "value": "id,title,price,thumbnail,category,rating,stock",
                  "description": "Comma-separated list of fields to include in the response (reduces payload size)."
                }
              ]
            },
            "description": "Returns a paginated list of all products. Adjust `limit` and `skip` for infinite scroll pagination. The `select` parameter limits the response to only the fields needed by the ProductCard component."
          },
          "response": []
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text",
                "description": "JWT token returned from the Login request."
              }
            ],
            "url": {
              "raw": "https://dummyjson.com/products/search?q=phone&limit=20&skip=0&select=id,title,price,thumbnail,category,rating,stock",
              "protocol": "https",
              "host": ["dummyjson", "com"],
              "path": ["products", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "phone",
                  "description": "The search query string. Dispatched from the debounced SearchBar component (350ms delay)."
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Number of results per page."
                },
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Number of results to skip."
                },
                {
                  "key": "select",
                  "value": "id,title,price,thumbnail,category,rating,stock",
                  "description": "Fields to include in the response."
                }
              ]
            },
            "description": "Searches for products matching the query string `q`. Used by the SearchBar component with a 350ms debounce to avoid excessive API calls on each keystroke."
          },
          "response": []
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text",
                "description": "JWT token returned from the Login request."
              }
            ],
            "url": {
              "raw": "https://dummyjson.com/products/1",
              "protocol": "https",
              "host": ["dummyjson", "com"],
              "path": ["products", "1"]
            },
            "description": "Fetches the full details for a single product by its numeric ID. Used by the ProductDetailClient component on the dynamic route /products/[id]. Returns the complete product object including images, reviews, dimensions, and meta."
          },
          "response": []
        },
        {
          "name": "Get Products By Category",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text",
                "description": "JWT token returned from the Login request."
              }
            ],
            "url": {
              "raw": "https://dummyjson.com/products/category/smartphones?limit=20&skip=0&select=id,title,price,thumbnail,category,rating,stock",
              "protocol": "https",
              "host": ["dummyjson", "com"],
              "path": ["products", "category", "smartphones"],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": "Number of products to return."
                },
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Number of products to skip."
                },
                {
                  "key": "select",
                  "value": "id,title,price,thumbnail,category,rating,stock",
                  "description": "Fields to include in the response."
                }
              ]
            },
            "description": "Returns all products belonging to the specified category slug. Triggered when the user selects a chip in the CategoryFilter component. Replace `smartphones` in the path with any valid category slug from the Get All Categories endpoint."
          },
          "response": []
        }
      ],
      "description": "Endpoints for fetching product lists, searching, and retrieving product details."
    },
    {
      "name": "Categories",
